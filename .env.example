# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.
#
# All EXPO_PUBLIC_* variables are embedded in the JavaScript bundle at build
# time and are visible to anyone who unpacks the app binary.  Never put a
# production secret (e.g. an Anthropic API key) directly in an EXPO_PUBLIC_*
# variable.  Use a backend proxy instead: the proxy holds the real secret
# server-side and the app only talks to the proxy.

# ── Receipt scanning ──────────────────────────────────────────────────────────
# URL of your backend receipt-scanning endpoint.
# When unset the receipt scanner is disabled — no crash, just a clear
# "not available" message shown to the user before they open the camera.
#
# Your backend must accept:   POST  { image: "<base64 jpeg>" }
# and return:                 200   <ExtractedReceipt JSON>
# See lib/receipts/remoteProvider.ts for the full response shape and the
# error codes the client handles (network_error, api_error, parse_error,
# unreadable).
#
# Example: EXPO_PUBLIC_RECEIPT_SCAN_URL=https://api.yourapp.com/receipt-scan
EXPO_PUBLIC_RECEIPT_SCAN_URL=

# ── AI budget review ──────────────────────────────────────────────────────────
# Controls which AI analysis provider is used for the Budget Review screen.
#
# 'mock'   (default) — fully offline, data-driven analysis computed on-device.
#                      No network call.  Works without any other env vars set.
# 'remote'           — calls EXPO_PUBLIC_AI_ENDPOINT with the full AnalysisInput
#                      payload and expects a BudgetAnalysisResponse in return.
#                      Requires EXPO_PUBLIC_AI_ENDPOINT to be set.
EXPO_PUBLIC_AI_PROVIDER=mock

# URL of your backend AI analysis endpoint.
# Only used when EXPO_PUBLIC_AI_PROVIDER=remote.
#
# Your backend must accept:   POST  <AnalysisInput JSON body>
# and return:                 200   <BudgetAnalysisResponse JSON>
# See lib/ai/types.ts for both shapes.
#
# Example: EXPO_PUBLIC_AI_ENDPOINT=https://api.yourapp.com/budget-analysis
EXPO_PUBLIC_AI_ENDPOINT=

# Optional bearer token sent as  Authorization: Bearer <token>  to the AI
# endpoint.  Only used when EXPO_PUBLIC_AI_PROVIDER=remote.
#
# SECURITY WARNING ─────────────────────────────────────────────────────────────
# EXPO_PUBLIC_* values are baked into the JS bundle and are readable by anyone
# who downloads your app.  Do NOT put a real Anthropic API key (or any other
# production secret) here.
#
# Recommended approach: your backend holds the Anthropic key.  Authenticate
# the mobile client with a short-lived session token (e.g. issued after a
# login or device-check flow) and set that token here.  The proxy then
# exchanges it for the real key server-side, keeping the secret off the device.
EXPO_PUBLIC_AI_API_KEY=
